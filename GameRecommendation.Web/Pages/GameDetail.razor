@page "/games/{id:int}"
@attribute [Authorize]
@inject GamesService GamesService
@inject RatingsService RatingsService
@inject NavigationManager Navigation

@if (isLoading)
{
    <p>Loading...</p>
}
else if (game == null)
{
    <p class="text-danger">Game not found.</p>
}
else
{
    <div class="row">
        <div class="col-md-4">
            <img src="@game.ImageUrl" class="img-fluid rounded" alt="@game.Name" />
        </div>
        <div class="col-md-8">
            <h2>@game.Name</h2>
            <p class="text-muted">Released @game.ReleaseDate.ToString("MMMM yyyy")</p>
            <p>@game.Description</p>

            @if (game.Tags.Any())
            {
                <div class="mb-3">
                    @foreach (var tag in game.Tags)
                    {
                        <span class="badge bg-secondary me-1">@tag</span>
                    }
                </div>
            }

            <div class="mt-3">
                <h5>Your Rating</h5>
                <RatingControl GameId="@game.Id" CurrentRating="@game.UserRating" OnRatingChanged="RefreshGame" />
            </div>

            <button class="btn btn-outline-secondary mt-3" @onclick='() => Navigation.NavigateTo("/games")'>
                Back to Games
            </button>
        </div>
    </div>
}

@code {
    [Parameter] public int Id { get; set; }

    private GamesService.GameDetailResponse? game;
    private bool isLoading;

    protected override async Task OnInitializedAsync()
    {
        await RefreshGame();
    }

    private async Task RefreshGame()
    {
        isLoading = true;
        game = await GamesService.GetGameAsync(Id);
        isLoading = false;
    }
}